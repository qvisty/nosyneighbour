# Copy this file to .env and fill in your values.
# NEVER commit .env to git - it is in .gitignore.

# DMI climate API key (https://confluence.govcloud.dk/display/FDAPI)
# Required for /api/climate
DMI_API_KEY=

# Datafordeler credentials for SVUR historical valuations
# (https://datafordeler.dk - free self-service signup)
# If unset, /api/valuations falls back to current valuation only.
DATAFORDELER_USER=
DATAFORDELER_PASS=

# Optional SSL (leave blank for Render - Render handles TLS automatically)
# SSL_CERTFILE=
# SSL_KEYFILE=

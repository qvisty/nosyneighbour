# Copy this file to .env and fill in your values.
# NEVER commit .env to git - it is in .gitignore.

# Add your API keys here, e.g.:
# MY_API_KEY=your_key_here

# Dataforsyningen token — register free at https://dataforsyningen.dk/
# Required for aerial photo in PDF reports
# DATAFORSYNINGEN_TOKEN=your_token_here

# Rejseplanen API 2.0 — register free at https://labs.rejseplanen.dk
# REJSEPLANEN_ACCESS_ID=your_access_id_here

# Datafordeler service user — for authenticated access to datafordeler.dk APIs
# DATAFORDELER_USERNAME=your_username_here
# DATAFORDELER_PASSWORD=your_password_here

# Optional SSL (leave blank for Render - Render handles TLS automatically)
# SSL_CERTFILE=
# SSL_KEYFILE=
